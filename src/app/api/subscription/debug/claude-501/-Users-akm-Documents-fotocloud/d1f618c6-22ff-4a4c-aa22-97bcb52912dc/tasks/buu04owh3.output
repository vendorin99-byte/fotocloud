er3Months\":\"/ 3 bulan\",\"perYear\":\"/ tahun\",\"oneTime\":\"sekali bayar\",\"mostPopular\":\"Paling Populer\",\"featureFullAccess\":\"Akses Pro Penuh\",\"featureUnlimitedProject\":\"Unlimited Project\",\"featureUnlimitedPhotos\":\"Unlimited Photos\",\"featurePrioritySupport\":\"Prioritas Support\",\"featureMax2Devices\":\"Maksimal 2 perangkat/user\",\"featureFutureUpdates\":\"Update Gratis Selamanya\",\"featureSave15\":\"Hanya 13rb/bulan\",\"featureSave50\":\"Gratis 2 bulan\",\"featureBundlePerMonth3\":\"Hanya 43rb/bulan\",\"featureBundlePerMonth12\":\"Gratis 2 bulan\",\"featureBundleIncludesBoth\":\"Bundle Client Desk + Fastpik\",\"featureBundleAllClientDesk\":\"Dan semua fitur Client Desk\",\"featureBundleSyncClientDesk\":\"Bisa sync data ke Client Desk\",\"featurePayOnce\":\"Terbatas untuk 100 user pertama\",\"coffeePrice\":\"Seharga 1 gelas kopi ☕\",\"billingAuto\":\"Tagihan otomatis diperbarui\",\"billingManualRenew\":\"Tidak auto-debit. Perpanjangan dilakukan manual.\",\"billingOnce\":\"Tagihan sekali bayar\",\"modeSingleLabel\":\"Fastpik\",\"modeBundleLabel\":\"Bundle\",\"crossProductHint\":\"Butuh sistem manajemen klien dari awal sampai akhir?\",\"crossProductLinkLabel\":\"Apa itu Client Desk?\",\"selectPlan\":\"Pilih Paket\",\"renewPlan\":\"Perpanjang Paket\",\"currentPlan\":\"Paket Saat Ini\",\"paymentNote\":\"Pembayaran diproses dengan aman oleh Mayar.id.\",\"paymentMethods\":\"Hanya mendukung QRIS.\",\"renewalNote\":\"Bisa untuk pembelian baru atau perpanjangan. Jika langganan masih aktif, durasi paket baru akan ditambahkan ke tanggal berakhir saat ini. Gunakan email yang sama dengan akun Fastpik agar perpanjangan masuk ke akun yang benar.\"},\"Profile\":{\"title\":\"Profil Saya\",\"description\":\"Kelola informasi akun Anda\",\"name\":\"Nama\",\"namePlaceholder\":\"Nama Anda\",\"email\":\"Email\",\"emailHint\":\"Email tidak dapat diubah\",\"save\":\"Simpan Perubahan\",\"saving\":\"Menyimpan...\",\"saveSuccess\":\"Profil berhasil disimpan!\",\"saveError\":\"Gagal menyimpan profil\",\"avatarError\":\"Gagal menyimpan foto profil\",\"resetPassword\":\"Reset Password\",\"resetEmailSent\":\"Link reset password telah dikirim ke email Anda.\",\"upgrade\":\"Upgrade\",\"changePlan\":\"Ganti Paket\",\"membershipStatus\":\"Status Membership\",\"validUntil\":\"Berlaku sampai\",\"foreverAccess\":\"Akses selamanya\",\"month\":\"Bulan\",\"months\":\"Bulan\",\"year\":\"Tahun\",\"trialInfo\":\"Anda sedang dalam masa trial\",\"projectUsage\":\"Project: {used}/{limit}\",\"daysRemaining\":\"Sisa waktu trial: {days} hari\",\"kelolaPaket\":\"Kelola Paket\",\"currentPlan\":\"Paket Saat Ini\"},\"ProfilePackage\":{\"title\":\"Paket\",\"subtitle\":\"Lihat paket yang sedang aktif dan riwayat langganan akun Anda.\",\"currentPackage\":\"Paket sekarang\",\"noActivePackage\":\"Belum ada paket aktif\",\"notSubscribed\":\"Belum berlangganan\",\"noActivePackageDescription\":\"Pilih paket untuk mengaktifkan akses Pro.\",\"validUntil\":\"Berlaku sampai {date} ({days} hari lagi)\",\"expiredOn\":\"Expired pada {date}\",\"validForever\":\"Berlaku selamanya\",\"changePackage\":\"Ganti Paket\",\"viewPackages\":\"Lihat Paket\",\"startDate\":\"Tanggal mulai\",\"endDate\":\"Tanggal berakhir\",\"forever\":\"Selamanya\",\"transaction\":\"Transaksi\",\"historyTitle\":\"Riwayat Langganan\",\"historySubtitle\":\"Catatan trial, pembelian, perpanjangan, dan perubahan paket.\",\"emptyHistory\":\"Belum ada riwayat langganan.\",\"historyLoadError\":\"Riwayat langganan belum bisa dimuat. Pastikan migration subscription_history sudah dijalankan.\"},\"AdminSecret\":{\"title\":\"Admin Panel\",\"enterSecretKey\":\"Masukkan Kunci Admin\",\"enterKeyDesc\":\"Masukkan kunci rahasia untuk mengakses panel admin\",\"secretKeyLabel\":\"Kunci Rahasia\",\"secretKeyPlaceholder\":\"Masukkan kunci admin...\",\"unlock\":\"Buka Kunci\",\"invalidKey\":\"Kunci tidak valid\",\"userManagement\":\"Manajemen User\",\"createTrialAccount\":\"Buat Akun Trial\",\"inviteTrialUser\":\"Undang User Trial\",\"inviteTrialUserDesc\":\"User akan menerima email undangan dan dapat membuat password sendiri\",\"sendInvite\":\"Kirim Undangan\",\"name\":\"Nama\",\"email\":\"Email\",\"password\":\"Password\",\"trialDuration\":\"Durasi Trial\",\"day\":\"hari\",\"days\":\"hari\",\"create\":\"Buat Akun\",\"creating\":\"Membuat...\",\"usersList\":\"Daftar User\",\"refresh\":\"Refresh\",\"newUser\":\"User Baru\",\"plan\":\"Paket\",\"expires\":\"Berakhir\",\"registered\":\"Terdaftar\",\"actions\":\"Aksi\",\"edit\":\"Edit\",\"delete\":\"Hapus\",\"noUsers\":\"Belum ada user\",\"deleteUser\":\"Hapus User\",\"deleteUserConfirm\":\"Apakah Anda yakin ingin menghapus\",\"thisActionCannot\":\"Tindakan ini tidak dapat dibatalkan.\",\"cancel\":\"Batal\",\"deleting\":\"Menghapus...\",\"editSubscription\":\"Edit Langganan\",\"modifySubFor\":\"Ubah langganan untuk\",\"expiryDate\":\"Masa Berlaku Berakhir\",\"save\":\"Simpan\",\"or\":\"Atau\",\"changePlan\":\"Ganti Paket\",\"selectPlan\":\"Pilih paket\",\"trial15days\":\"Trial (15 hari)\",\"proMonthly\":\"Pro Monthly\",\"proQuarterly\":\"Pro Quarterly\",\"proYearly\":\"Pro Yearly\",\"lifetime\":\"Lifetime\",\"change\":\"Ganti\",\"trial\":\"Trial\",\"noPlan\":\"Tidak Ada Paket\",\"never\":\"Selamanya\"},\"Features\":{\"pageTitle\":\"Semua Fitur Fastpik\",\"pageDescription\":\"Temukan semua fitur yang membuat proses culling foto Anda lebih mudah dan efisien.\",\"coreFeatures\":\"Fitur Utama\",\"additionalFeatures\":\"Fitur Tambahan\",\"startNow\":\"Mulai Sekarang\"},\"FAQ\":{\"pageTitle\":\"Pertanyaan Umum (FAQ)\",\"pageDescription\":\"Temukan jawaban untuk pertanyaan yang sering diajukan tentang Fastpik.\",\"categoryGeneral\":\"Umum\",\"categoryFeatures\":\"Fitur\",\"categoryPricing\":\"Harga \u0026 Pembayaran\",\"categoryTechnical\":\"Teknis\",\"q1\":\"Apa itu Fastpik?\",\"a1\":\"Fastpik adalah platform pemilihan foto online untuk fotografer profesional. Klienmu bisa memilih foto langsung dari browser tanpa perlu download aplikasi apapun.\",\"q2\":\"Apakah klien saya perlu membuat akun?\",\"a2\":\"Tidak! Klien cukup membuka link yang kamu kirim via WhatsApp. Tidak perlu registrasi atau download aplikasi.\",\"q3\":\"Bagaimana cara kerja Fastpik?\",\"a3\":\"Cukup 3 langkah: (1) Buat project dan masukkan link Google Drive, (2) Bagikan link gallery ke klien via WhatsApp, (3) Klien pilih foto dan kamu terima hasilnya.\",\"q4\":\"Apakah ada batasan jumlah foto yang bisa diupload?\",\"a4\":\"Untuk user Pro, tidak ada batasan jumlah foto. Foto diambil langsung dari Google Drive kamu, jadi kapasitas tergantung storage Google Drive.\",\"q5\":\"Format foto apa saja yang didukung?\",\"a5\":\"Fastpik mendukung format gambar populer seperti JPG, JPEG, PNG, dan WEBP yang tersimpan di Google Drive kamu.\",\"q6\":\"Berapa harga langganan Fastpik?\",\"a6\":\"Mulai dari Rp 15.000/bulan untuk paket 1 bulan, Rp 39.000/3 bulan, atau Rp 149.000/tahun. Semua paket mendapat akses Pro penuh.\",\"q7\":\"Metode pembayaran apa yang tersedia?\",\"a7\":\"Kami hanya mendukung pembayaran melalui QRIS.\",\"q8\":\"Apakah ada trial gratis?\",\"a8\":\"Ya! Kamu bisa mencoba Fastpik gratis selama 5 hari dengan fitur Pro lengkap.\",\"q9\":\"Apakah link gallery bisa diproteksi password?\",\"a9\":\"Ya, kamu bisa menambahkan password pada setiap project untuk keamanan ekstra.\",\"q10\":\"Bisakah saya mengatur durasi link?\",\"a10\":\"Ya, kamu bisa mengatur masa aktif link secara terpisah untuk memilih foto dan download foto.\",\"q11\":\"Apakah Fastpik bisa digunakan di HP?\",\"a11\":\"Ya! Fastpik memiliki desain responsif yang optimal di HP, tablet, maupun desktop.\",\"q12\":\"Bagaimana jika saya butuh bantuan?\",\"a12\":\"Kamu bisa menghubungi kami via Instagram @ryanekoapps atau melalui WhatsApp untuk support prioritas.\",\"backToHome\":\"Kembali ke Beranda\",\"stillHaveQuestions\":\"Masih ada pertanyaan?\",\"contactUs\":\"Hubungi kami via Instagram\"},\"Tutorial\":{\"pageTitle\":\"Tutorial\",\"pageDescription\":\"Panduan langkah demi langkah untuk menggunakan Fastpik\",\"step1Title\":\"Membuat Project Baru\",\"step1Desc\":\"Cara membuat project dan menghubungkan dengan Google Drive\",\"step1Detail1\":\"Buka Dashboard dan klik tombol 'Buat Proyek Baru'\",\"step1Detail2\":\"Masukkan nama klien dan link Google Drive yang berisi foto-foto\",\"step1Detail3\":\"Atur jumlah maksimal foto yang boleh dipilih klien\",\"step1Detail4\":\"Tambahkan password jika diperlukan untuk keamanan ekstra\",\"step1Detail5\":\"Atur durasi link untuk pilih foto dan download foto\",\"step1Detail6\":\"Klik 'Buat Link' dan link gallery siap dibagikan!\",\"step2Title\":\"Mengirim Link ke Klien\",\"step2Desc\":\"Cara membagikan link gallery ke klien via WhatsApp\",\"step2Detail1\":\"Setelah link dibuat, klik 'Kirim ke WhatsApp Klien'\",\"step2Detail2\":\"Template pesan otomatis ter-generate dengan link gallery\",\"step2Detail3\":\"Kamu juga bisa menyalin link dan mengirimkannya secara manual\",\"step2Detail4\":\"Klien membuka link di browser — tidak perlu install aplikasi\",\"step3Title\":\"Menerima Hasil Pilihan\",\"step3Desc\":\"Cara melihat dan mengelola foto yang dipilih klien\",\"step3Detail1\":\"Cek tab 'Status Klien' di dashboard untuk melihat progress\",\"step3Detail2\":\"Status berubah otomatis: Belum Memilih → Sedang Memilih → Ditinjau\",\"step3Detail3\":\"Klien mengirim daftar foto terpilih ke WhatsApp admin\",\"step3Detail4\":\"Tandai sebagai 'Sudah Ditinjau' setelah selesai memeriksa\",\"step4Title\":\"Pengaturan Lanjutan\",\"step4Desc\":\"Kustomisasi template pesan dan bot Telegram\",\"step4Detail1\":\"Buka Pengaturan → Tab Template Pesan untuk kustomisasi pesan WhatsApp\",\"step4Detail2\":\"Atur template untuk link awal, link tambahan, hasil pilihan, dan pengingat\",\"step4Detail3\":\"Setup Bot Telegram untuk notifikasi otomatis saat project mendekati expired\",\"step4Detail4\":\"Atur hari reminder (H-1, H-3, H-7, dll) sesuai kebutuhan\",\"step5Title\":\"Import Batch Project\",\"step5Desc\":\"Cara membuat banyak project sekaligus dari spreadsheet\",\"step5Detail1\":\"Klik tombol 'Buat Batch' di dashboard\",\"step5Detail2\":\"Download template XLSX dan isi data klien\",\"step5Detail3\":\"Upload file spreadsheet (.xlsx atau .csv)\",\"step5Detail4\":\"Preview data, perbaiki jika ada error, lalu import\",\"backToDashboard\":\"Kembali ke Dashboard\",\"tip\":\"Tips\",\"tipContent\":\"Gunakan fitur Folder untuk mengorganisir project berdasarkan event atau tanggal. Drag \u0026 drop project ke folder yang diinginkan!\"}},\"now\":\"$undefined\",\"timeZone\":\"Asia/Shanghai\",\"children\":\"$L12\"}]\n"])</script><script>self.__next_f.push([1,"12:[\"$\",\"$L13\",null,{\"attribute\":\"class\",\"defaultTheme\":\"system\",\"enableSystem\":true,\"children\":[\"$\",\"$L14\",null,{\"tenant\":{\"id\":\"cf9d23eb-5cbc-47be-b723-cc0c8d8ccebe\",\"slug\":\"fastpik\",\"name\":\"Fastpik\",\"domain\":\"fastpik.ryanekoapp.web.id\",\"logoUrl\":\"/fastpik-logo.png\",\"faviconUrl\":\"\",\"primaryColor\":\"#7c3aed\",\"footerText\":\"\"},\"children\":[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L3\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}]}]\n9:null\nd:[[\"$\",\"title\",\"0\",{\"children\":\"Pricing - Fastpik\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Select your photos quickly and easily.\"}],[\"$\",\"meta\",\"2\",{\"property\":\"og:title\",\"content\":\"Fastpik - Photo Culling\"}],[\"$\",\"meta\",\"3\",{\"property\":\"og:description\",\"content\":\"Select your photos quickly and easily.\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:image\",\"content\":\"https://fastpik.ryanekoapp.web.id/fastpik-logo.png\"}],[\"$\",\"meta\",\"5\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"6\",{\"name\":\"twitter:tit