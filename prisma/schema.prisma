generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Required Tables ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Fotografer / User ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed, null if using OAuth sign-in

  businessName  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Google Drive credentials (per-photographer OAuth)
  googleAccessToken  String?  @db.Text
  googleRefreshToken String?  @db.Text
  googleTokenExpiry  DateTime?
  googleEmail        String?

  // Subscription
  plan           String   @default("free")  // free | pro
  planExpiresAt  DateTime?
  trialEndsAt    DateTime?  // 7-day free Pro trial

  // Password reset
  resetToken     String?   @unique  // Hashed reset token
  resetTokenExpiry DateTime?  // Reset token expiry (1 hour)

  // Admin flag
  isAdmin        Boolean   @default(false)

  accounts         Account[]
  sessions         Session[]
  projects         Project[]
  subscriptions    Subscription[]
  chatMessages     ChatMessage[]
  balance          PhotographerBalance?
  transactions     Transaction[]
  payoutRequests   PayoutRequest[]
}

// ─── Subscription ─────────────────────────────────────────────────────────────

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Midtrans
  orderId         String   @unique
  snapToken       String?
  status          String   @default("pending")  // pending | paid | failed | expired
  amount          Int      // IDR, e.g. 99000
  planDurationDays Int     @default(30)          // how many days of pro access

  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  clientName  String?

  // Google Drive folder linked to this project
  driveFolderId  String?
  driveFolderUrl String?
  syncStatus     String   @default("pending") // pending | syncing | synced | error
  lastSyncedAt   DateTime?

  photographerId String
  photographer   User   @relation(fields: [photographerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  watermarkEnabled Boolean @default(false)

  accessTokens  AccessToken[]
  mediaItems    MediaItem[]
  galleryViews  GalleryView[]
}

// ─── Gallery Analytics ────────────────────────────────────────────────────────

model GalleryView {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  accessTokenId String?
  viewedAt      DateTime @default(now())
}

// ─── Testimonial ─────────────────────────────────────────────────────────────

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  content   String   @db.Text
  rating    Int      @default(5)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── App Settings (harga subscription dll) ───────────────────────────────────

model AppSettings {
  id              String @id @default("default")
  // Pro pricing per period (in IDR)
  pro1MonthPrice  Int    @default(9900)    // Rp 9.9K
  pro3MonthPrice  Int    @default(27000)   // Rp 27K
  pro12MonthPrice Int    @default(99000)   // Rp 99K
  // Trial
  trialDays       Int    @default(7)       // 7-day trial
  // Limits
  freeProjectLimit Int   @default(1)
  updatedAt       DateTime @updatedAt
}

// ─── Access Token (unique URL per client/stakeholder) ────────────────────────

model AccessToken {
  id    String @id @default(cuid())
  token String @unique @default(cuid())
  slug  String? @unique  // human-readable URL: domain/slug
  label String? // "Link Bride", "Link Wedding Planner"

  isActive    Boolean  @default(true)
  canDownload Boolean  @default(true)
  canComment  Boolean  @default(true)
  expiresAt   DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  reviews  MediaReview[]
  comments Comment[]
}

// ─── Media Item (cache dari Google Drive) ────────────────────────────────────

model MediaItem {
  id          String @id @default(cuid())
  driveFileId String?
  name        String
  mimeType    String
  type        String // "photo" | "video" | "other"

  thumbnailUrl String?  @db.Text
  webViewUrl   String?  @db.Text
  downloadUrl  String?  @db.Text
  fileSize     BigInt?
  width        Int?
  height       Int?
  durationSecs Int?
  takenAt      DateTime?

  sortOrder Int     @default(0)
  isHidden  Boolean @default(false)

  // Photo sales
  price       Int?    // IDR, null = not for sale, 0 = free
  isForSale   Boolean @default(false)
  category    String? // "wedding" | "portrait" | "landscape" etc
  displayName String? // Display name untuk marketplace (beda dari file name)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  reviews     MediaReview[]
  comments    Comment[]
  purchases   Purchase[]
  photoReviews PhotoReview[]

  @@unique([projectId, driveFileId], where: { driveFileId: { not: null } })
  @@index([isForSale])
  @@index([category])
}

// ─── Media Review (status per media × access token) ──────────────────────────

model MediaReview {
  id            String   @id @default(cuid())
  status        String   @default("pending") // pending | approved | revision_requested
  revisionNote  String?  @db.Text
  reviewedAt    DateTime?

  mediaItemId   String
  mediaItem     MediaItem   @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  accessTokenId String
  accessToken   AccessToken @relation(fields: [accessTokenId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mediaItemId, accessTokenId])
}

// ─── Comment ─────────────────────────────────────────────────────────────────

model Comment {
  id           String  @id @default(cuid())
  authorName   String
  body         String  @db.Text
  timestampSecs Int?   // for video comments: position in video

  mediaItemId   String
  mediaItem     MediaItem   @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  accessTokenId String
  accessToken   AccessToken @relation(fields: [accessTokenId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─── Live Chat ────────────────────────────────────────────────────────────────
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  message   String   @db.Text
  isFromAdmin Boolean @default(false)  // true if message from admin
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ─── Photo Purchase (marketplace) ─────────────────────────────────────────────
model Purchase {
  id              String   @id @default(cuid())

  // Buyer info
  buyerEmail      String
  buyerName       String?

  // Photo info
  mediaItemId     String
  mediaItem       MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  // Payment
  amount          Int      // IDR price at time of purchase
  paymentMethod   String   @default("midtrans") // midtrans | etc
  midtransOrderId String?  @unique
  status          String   @default("pending") // pending | paid | failed

  // Download tracking
  downloadCount   Int      @default(0)
  lastDownloadedAt DateTime?
  expiresAt       DateTime? // download expires after X days (optional)

  createdAt DateTime @default(now())
  paidAt    DateTime?

  transactions Transaction[]

  @@index([buyerEmail])
  @@index([mediaItemId])
  @@index([status])
  @@index([createdAt])
}

// ─── Photo Review (rating dari pembeli) ───────────────────────────────────────
model PhotoReview {
  id          String   @id @default(cuid())

  mediaItemId String
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

  buyerEmail  String
  buyerName   String?
  rating      Int      @default(5) // 1-5 stars
  comment     String?  @db.Text

  createdAt DateTime @default(now())

  @@unique([mediaItemId, buyerEmail])
  @@index([mediaItemId])
  @@index([rating])
}

// ─── Photographer Balance & Payout ────────────────────────────────────────
model PhotographerBalance {
  id              String   @id @default(cuid())

  photographerId  String   @unique
  photographer    User     @relation(fields: [photographerId], references: [id], onDelete: Cascade)

  balance         Int      @default(0)  // IDR, total available balance
  totalEarned     Int      @default(0)  // IDR, total earned lifetime
  totalPaidOut    Int      @default(0)  // IDR, total paid out

  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

// ─── Transaction (track all money movements) ───────────────────────────────
model Transaction {
  id              String   @id @default(cuid())

  photographerId  String
  photographer    User     @relation(fields: [photographerId], references: [id], onDelete: Cascade)

  type            String   // "sale" | "payout" | "refund"
  amount          Int      // IDR
  description     String?

  // Related to purchase (if type = "sale")
  purchaseId      String?
  purchase        Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  // Related to payout (if type = "payout")
  payoutRequestId String?
  payoutRequest   PayoutRequest? @relation(fields: [payoutRequestId], references: [id], onDelete: SetNull)

  status          String   @default("completed") // "pending" | "completed" | "failed"

  createdAt       DateTime @default(now())

  @@index([photographerId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// ─── Payout Request ───────────────────────────────────────────────────────
model PayoutRequest {
  id              String   @id @default(cuid())

  photographerId  String
  photographer    User     @relation(fields: [photographerId], references: [id], onDelete: Cascade)

  amount          Int      // IDR, amount requested
  status          String   @default("pending") // "pending" | "approved" | "rejected" | "processing" | "completed"

  bankName        String?
  bankAccount     String?  // encrypted
  accountHolder   String?

  approvedAt      DateTime?
  rejectedAt      DateTime?
  completedAt     DateTime?
  rejectionReason String?  @db.Text

  transactions    Transaction[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([photographerId])
  @@index([status])
  @@index([createdAt])
}

// ─── Commission Config ─────────────────────────────────────────────────────
model CommissionConfig {
  id              String   @id @default("default")

  photographerPercent Int  @default(80)  // 80% to photographer
  platformPercent     Int  @default(20)  // 20% to platform

  updatedAt       DateTime @updatedAt
}

