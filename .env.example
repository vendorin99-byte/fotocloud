# Database
# PostgreSQL lokal: postgresql://postgres:postgres@localhost:5432/fotocloud
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://..."

# NextAuth
NEXTAUTH_SECRET="random-string-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (buat di console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Enkripsi Google tokens (generate: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=""

# Midtrans (sandbox untuk dev, production untuk live)
# Ambil dari: https://dashboard.sandbox.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
